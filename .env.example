# ==============================================
# Fitness Tracker v2 - Environment Variables
# ==============================================

# Application Settings
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
APP_VERSION=2.0.0

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://fitness_user:your_password@db:5432/fitness_tracker
POSTGRES_DB=fitness_tracker
POSTGRES_USER=fitness_user
POSTGRES_PASSWORD=your_strong_database_password

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# CORS Settings
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Apple Health Integration
APPLE_HEALTH_ENABLED=true
APPLE_HEALTH_API_KEY=your_apple_health_api_key

# Security
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs
WEATHER_API_KEY=your_weather_api_key
NUTRITION_API_KEY=your_nutrition_api_key

# Monitoring
GRAFANA_PASSWORD=your_grafana_admin_password
PROMETHEUS_ENABLED=true

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# File Storage
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH=/app/data/uploads

# Feature Flags
FEATURE_APPLE_HEALTH=true
FEATURE_SOCIAL_SHARING=false
FEATURE_PREMIUM=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Synology Specific
SYNOLOGY_HOST=your-synology-ip
SYNOLOGY_USER=your-synology-user
SYNOLOGY_SSH_PORT=22

# Development Only (не используйте в продакшене)
DEV_DATABASE_URL=sqlite:///./fitness_tracker_dev.db
DEV_DEBUG=true
DEV_RELOAD=true

# Testing
TEST_DATABASE_URL=sqlite:///./test_fitness_tracker.db
TEST_DEBUG=false

# ==============================================
# Инструкции по настройке:
# ==============================================
# 1. Скопируйте этот файл как .env
# 2. Замените все значения 'your_*' на реальные
# 3. Сгенерируйте надежные пароли и ключи
# 4. НЕ коммитьте .env файл в Git!
# ==============================================
